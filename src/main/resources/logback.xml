<!-- xml -->
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>app.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- keep console + file -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- application package log level is configurable via APP_LOG_LEVEL (default INFO) -->
    <logger name="com.bs.basicktorserver" level="${APP_LOG_LEVEL:-INFO}"/>
    <logger name="org.eclipse.jetty" level="INFO"/>
    <logger name="io.netty" level="INFO"/>

    <!-- Enable Ktor request/response logging -->
    <logger name="io.ktor.server.plugins.calllogging" level="DEBUG"/>
    <logger name="ktor.application" level="DEBUG"/>
    <logger name="io.ktor" level="INFO"/>
    <logger name="Application" level="DEBUG"/>
    <logger name="Ktor" level="DEBUG"/>
</configuration>
